# Backend, Alembic, and CLI commands load this repo-root `.env` automatically.
# Explicit process environment variables still override these values.

# Required local runtime settings
RFX_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rfx_rag_expert
RFX_STORAGE_ROOT=./storage

# Required for provider-backed extraction, drafting, and historical seed import
OPENAI_API_KEY=

# Optional base model defaults
RFX_OPENAI_RESPONSE_MODEL=gpt-5.2
RFX_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional local identity defaults
RFX_LOCAL_TENANT_SLUG=local-workspace
RFX_LOCAL_USER_EMAIL=local.user@example.test
RFX_LOCAL_USER_NAME=Local Admin
RFX_LOCAL_TENANT_NAME=Local Workspace
