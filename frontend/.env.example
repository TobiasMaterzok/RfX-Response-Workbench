# Optional frontend development overrides for Vite.
# Copy to `frontend/.env.local` if you want to change the defaults.
# Developer-only panels stay hidden unless you explicitly opt in.

VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_TENANT_SLUG=local-workspace
VITE_USER_EMAIL=local.user@example.test
VITE_ENABLE_DEV_PANELS=false
